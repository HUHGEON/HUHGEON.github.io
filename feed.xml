---
layout: null
sitemap: false
---
<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ site.title | xml_escape }}</title>
    <description>{{ site.description | xml_escape }}</description>
    <link>{{ site.url }}{{ site.baseurl }}/</link>
    <atom:link href="{{ site.url }}{{ site.baseurl }}/feed.xml" rel="self" type="application/rss+xml" />
    <language>ko</language>
    <generator>Jekyll</generator>
    {%- assign feed_posts = site.pages | sort: "date" | reverse -%}
    {%- for post in feed_posts -%}
      {%- assign posting_date = post.date | date: "%Y-%m-%d" -%}
      {%- unless post.url contains "index.html" -%}
      {%- if posting_date != "1900-01-01" -%}
    <item>
      <title>{{ post.title | xml_escape }}</title>
      <link>{{ site.url }}{{ site.baseurl }}{{ post.url }}</link>
      <guid isPermaLink="true">{{ site.url }}{{ site.baseurl }}{{ post.url }}</guid>
      <pubDate>{{ post.date | date_to_rfc822 }}</pubDate>
      <description>{{ post.content | markdownify | strip_html | strip_newlines | truncate: 500 | xml_escape }}</description>
      {%- for tag in post.tags -%}
      <category>{{ tag | xml_escape }}</category>
      {%- endfor -%}
    </item>
      {%- endif -%}
      {%- endunless -%}
    {%- endfor -%}
  </channel>
</rss>
